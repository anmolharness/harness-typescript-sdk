{
  "name": "@anmolharness/harness-typescript-sdk",
  "version": "0.1.0",
  "description": "Unofficial TypeScript SDK for Harness Platform API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/anmolharness/harness-typescript-sdk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "harness",
    "sdk",
    "typescript",
    "ci-cd",
    "devops",
    "unofficial"
  ],
  "author": "Anmol Pandey",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
